webrpc = v1

name = node-ts
version = v1.0.0
basepath = /v1

service ExampleService
  - Ping() => ()
  - GetUser(userID: uint64) => (code: uint32, user: User)

type Username: string
type Age: uint32

struct User
  - ID: uint64
    + json = id

  - username: string
    + json = USERNAME

  - role: Kind

  - meta: map<string,any>

  - internalID: uint64
    + json = -

  - createdAt?: timestamp

enum Kind: uint32
  - USER
  - ADMIN

struct Page
  - num: uint32
