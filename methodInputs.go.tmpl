{{- define "methodInputs" -}}

{{- $method := .Method -}}
{{- $serviceApiName := .ServiceApiName -}}

{{- if gt (len $method.Inputs) 0 -}}
request: {{- if $method.Succinct -}}{{(index $method.Inputs 0).Type}}{{- else -}}{{$serviceApiName}}.{{$method.Name}}.Request{{- end -}}
{{- end -}}
{{- end -}}
