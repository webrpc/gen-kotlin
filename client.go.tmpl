{{define "client"}}

{{- $basepath := .BasePath -}}
{{- $schemaName := .SchemaName -}}
{{- $schemaPrefix := pascalCase $schemaName -}}
{{- $typeMap := .TypeMap -}}
{{- $types := .Types -}}
{{- $reservedTypeNames := dict -}}
{{- range $_, $type := $types -}}
    {{- set $reservedTypeNames $type.Name true -}}
{{- end -}}
{{- $usedApiNames := dict -}}
{{- $usedClientNames := dict -}}

{{- if .Services -}}
// region Service Metadata
{{ range $serviceIndex, $service := .Services}}
{{if gt $serviceIndex 0}}

{{end}}
{{- $serviceBaseName := ternary (hasPrefix $service.Name $schemaPrefix) $service.Name (printf "%s%s" $schemaPrefix $service.Name) -}}
{{- $serviceApiState := dict "name" "" "selected" false -}}
{{- range $_, $candidate := (list (printf "%sApi" $serviceBaseName) (printf "%sServiceApi" $serviceBaseName) (printf "%sWebRpcApi" $serviceBaseName) (printf "%sGeneratedRpcApi" $serviceBaseName) (printf "%sGeneratedRpcApi%d" $serviceBaseName $serviceIndex)) -}}
    {{- if not (get $serviceApiState "selected") -}}
        {{- $collisionState := dict "collision" false -}}
        {{- if or (exists $reservedTypeNames $candidate) (exists $usedApiNames $candidate) -}}
            {{- set $collisionState "collision" true -}}
        {{- end -}}
        {{- if not (get $collisionState "collision") -}}
            {{- set $serviceApiState "name" $candidate -}}
            {{- set $serviceApiState "selected" true -}}
            {{- set $usedApiNames $candidate true -}}
        {{- end -}}
    {{- end -}}
{{- end }}
{{- $serviceApiName := get $serviceApiState "name" -}}
{{- $serviceClientState := dict "name" "" "selected" false -}}
{{- range $_, $candidate := (list (printf "%sClient" $serviceBaseName) (printf "%sServiceClient" $serviceBaseName) (printf "%sWebRpcClient" $serviceBaseName) (printf "%sGeneratedRpcClient" $serviceBaseName) (printf "%sGeneratedRpcClient%d" $serviceBaseName $serviceIndex)) -}}
    {{- if not (get $serviceClientState "selected") -}}
        {{- $collisionState := dict "collision" false -}}
        {{- if or (exists $reservedTypeNames $candidate) (exists $usedClientNames $candidate) -}}
            {{- set $collisionState "collision" true -}}
        {{- end -}}
        {{- if not (get $collisionState "collision") -}}
            {{- set $serviceClientState "name" $candidate -}}
            {{- set $serviceClientState "selected" true -}}
            {{- set $usedClientNames $candidate true -}}
        {{- end -}}
    {{- end -}}
{{- end }}
{{- $serviceClientName := get $serviceClientState "name" -}}
object {{$serviceApiName}} {
    const val basePath: String = "{{$basepath}}{{$service.Name}}"
{{- range $_, $method := $service.Methods}}

    object {{$method.Name}} {
        const val path: String = "/{{$method.Name}}"
        const val urlPath: String = "{{$basepath}}{{$service.Name}}/{{$method.Name}}"
        {{- if and (not $method.Succinct) (gt (len $method.Inputs) 0) }}

        @Serializable
        data class Request(
            {{- range $_, $field := $method.Inputs}}
                {{- $isExportable := true -}}
                {{- range $meta := $field.Meta -}}
                    {{- if exists $meta "json" -}}
                        {{- if eq (printf "%v" (get $meta "json")) "-" -}}
                            {{- $isExportable = false -}}
                        {{- end -}}
                    {{- end -}}
                {{- end }}
                {{- if $isExportable }}
            @SerialName("{{template "codingKey" dict "Field" $field}}")
            val {{template "fieldName" dict "Field" $field}}: {{template "type" dict "Type" $field.Type "TypeMap" $typeMap}}{{if $field.Optional}}? = null{{end}},
                {{- end -}}
            {{- end}}
        )
        {{- end }}
        {{- if and (not $method.Succinct) (gt (len $method.Outputs) 0) }}

        @Serializable
        data class Response(
            {{- range $_, $field := $method.Outputs}}
                {{- $isExportable := true -}}
                {{- range $meta := $field.Meta -}}
                    {{- if exists $meta "json" -}}
                        {{- if eq (printf "%v" (get $meta "json")) "-" -}}
                            {{- $isExportable = false -}}
                        {{- end -}}
                    {{- end -}}
                {{- end }}
                {{- if $isExportable }}
            @SerialName("{{template "codingKey" dict "Field" $field}}")
            val {{template "fieldName" dict "Field" $field}}: {{template "type" dict "Type" $field.Type "TypeMap" $typeMap}}{{if $field.Optional}}? = null{{end}},
                {{- end -}}
            {{- end}}
        )
        {{- end }}

        {{- if eq (len $method.Inputs) 0 }}
        @Suppress("UNUSED_PARAMETER")
        {{- end }}
        fun encodeRequest({{if gt (len $method.Inputs) 0}}request: {{if $method.Succinct}}{{(index $method.Inputs 0).Type}}{{else}}Request{{end}}, {{end}}json: Json = WebRpcJson): String {
            {{- if eq (len $method.Inputs) 0 }}
            return "{}"
            {{- else }}
            return json.encodeToString(request)
            {{- end }}
        }
        {{- if eq (len $method.Outputs) 0 }}

        @Suppress("UNUSED_PARAMETER")
        fun decodeResponse(body: String, json: Json = WebRpcJson) {
            return
        }
        {{- else }}

        fun decodeResponse(body: String, json: Json = WebRpcJson): {{if $method.Succinct}}{{(index $method.Outputs 0).Type}}{{else}}Response{{end}} {
            return json.decodeFromString(body)
        }
        {{- end }}
    }
{{- end}}
}

class {{$serviceClientName}}(
    private val baseUrl: String,
    private val transport: WebRpcTransport,
    private val json: Json = WebRpcJson,
    private val headers: () -> Map<String, String> = { emptyMap() },
) {
    {{- range $_, $method := $service.Methods}}

    @Throws(WebRpcError::class, WebRpcTransportException::class)
    suspend fun {{firstLetterToLower $method.Name}}({{template "methodInputs" dict "Method" $method "ServiceApiName" $serviceApiName}}){{if gt (len $method.Outputs) 0}}: {{template "methodOutputs" dict "Method" $method "ServiceApiName" $serviceApiName}}{{end}} {
        return executeWebRpc(
            baseUrl = baseUrl,
            urlPath = {{$serviceApiName}}.{{$method.Name}}.urlPath,
            body = {{$serviceApiName}}.{{$method.Name}}.encodeRequest({{if gt (len $method.Inputs) 0}}request, {{end}}json),
            transport = transport,
            headers = headers(),
            json = json,
            decodeSuccess = { body, decodeJson ->
                {{$serviceApiName}}.{{$method.Name}}.decodeResponse(body, decodeJson)
            },
        )
    }
    {{- end}}
}
{{ end }}
// endregion
{{- end}}

{{end}}
